function addToBill() {
    const itemName = document.getElementById('billItemName').value.trim();
    const qty = parseInt(document.getElementById('billQty').value);
    const price = parseFloat(document.getElementById('billPrice').value);

    if (!itemName || qty <= 0 || price < 0) {
        alert('Sahama thagathuru purawanna!');
        return;
    }

    // Aluthma line eka meka
    const today = new Date().toISOString().split('T')[0]; // 2026-04-05 wage

    const existingItem = bill.find(item => item.name === itemName && item.price === price);
    if (existingItem) {
        existingItem.qty += qty;
    } else {
        bill.push({ name: itemName, qty: qty, price: price, date: today }); // date add kala
    }

    saveData();
    updateBillList();
    clearBillInputs();
}